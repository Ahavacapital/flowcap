// api/gmail/watch.js
// ─────────────────────────────────────────────────────────────
// Gmail Watcher — called by Vercel Cron every 5 minutes
// Scans your deals inbox, creates deals from new emails,
// attaches any PDF/image attachments as documents
//
// Vercel cron config (vercel.json):
// { "crons": [{ "path": "/api/gmail/watch", "schedule": "*/5 * * * *" }] }
// ─────────────────────────────────────────────────────────────

import { google } from 'googleapis'
import { supabaseAdmin, generateDealNumber, getBrokerByEmail } from '../../lib/supabase.js'
import { queueScrubJob } from '../scrubber/queue.js'

// Auth with Google using Service Account
function getGoogleAuth() {
  const creds = JSON.parse(process.env.GOOGLE_SERVICE_ACCOUNT_JSON)
  return new google.auth.GoogleAuth({
    credentials: creds,
    scopes: [
      'https://www.googleapis.com/auth/gmail.readonly',
      'https://www.googleapis.com/auth/gmail.modify',
    ],
    // IMPORTANT: The service account must be granted domain-wide delegation
    // in Google Workspace Admin → Security → API Controls → Domain-wide delegation
    // Add scope: https://www.googleapis.com/auth/gmail.readonly
    clientOptions: { subject: process.env.GMAIL_USER_EMAIL }
  })
}

export default async function handler(req, res) {
  // Secure the cron endpoint
  if (req.headers.authorization !== `Bearer ${process.env.CRON_SECRET}`) {
    return res.status(401).json({ error: 'Unauthorized' })
  }

  try {
    const auth = await getGoogleAuth()
    const gmail = google.gmail({ version: 'v1', auth })

    // Search for unread emails — adjust query as needed
    // e.g. add 'label:deals' if you filter with a Gmail label
    const query = `is:unread to:${process.env.GMAIL_USER_EMAIL}`
    
    const { data: listData } = await gmail.users.messages.list({
      userId: 'me',
      q: query,
      maxResults: 20,
    })

    const messages = listData.messages || []
    const results = []

    for (const msg of messages) {
      // Skip if already processed
      const { data: existing } = await supabaseAdmin
        .from('gmail_sync_log')
        .select('id')
        .eq('gmail_message_id', msg.id)
        .single()
      
      if (existing) continue

      try {
        const deal = await processGmailMessage(gmail, msg.id)
        results.push({ messageId: msg.id, dealId: deal?.id, status: 'created' })
        
        // Mark as read
        await gmail.users.messages.modify({
          userId: 'me',
          id: msg.id,
          requestBody: { removeLabelIds: ['UNREAD'] }
        })
      } catch (err) {
        console.error(`Failed to process message ${msg.id}:`, err)
        results.push({ messageId: msg.id, status: 'error', error: err.message })
        
        // Log the error
        await supabaseAdmin.from('gmail_sync_log').insert({
          gmail_message_id: msg.id,
          gmail_thread_id: msg.threadId,
          processed: false,
          error: err.message
        })
      }
    }

    return res.json({ processed: results.length, results })

  } catch (err) {
    console.error('Gmail watch error:', err)
    return res.status(500).json({ error: err.message })
  }
}

async function processGmailMessage(gmail, messageId) {
  const { data: message } = await gmail.users.messages.get({
    userId: 'me',
    id: messageId,
    format: 'full'
  })

  // Parse headers
  const headers = message.payload.headers
  const getHeader = (name) => headers.find(h => h.name.toLowerCase() === name.toLowerCase())?.value || ''
  
  const subject   = getHeader('Subject')
  const fromRaw   = getHeader('From')
  const fromEmail = fromRaw.match(/<(.+)>/)?.[1] || fromRaw.trim()
  const fromName  = fromRaw.match(/^(.+?)\s*</)?.[1]?.trim() || fromEmail

  // Extract email body text
  const bodyText = extractBody(message.payload)

  // Try to parse deal info from subject/body
  const parsed = parseDealFromEmail(subject, bodyText, fromEmail, fromName)

  // Look up broker by sender email
  const broker = await getBrokerByEmail(fromEmail)

  // Generate deal number
  const dealNumber = await generateDealNumber()

  // Create the deal
  const { data: deal, error } = await supabaseAdmin
    .from('deals')
    .insert({
      deal_number:    dealNumber,
      broker_id:      broker?.id || null,
      business_name:  parsed.businessName,
      contact_name:   parsed.contactName,
      contact_email:  parsed.contactEmail,
      contact_phone:  parsed.contactPhone,
      amount_requested: parsed.amountRequested,
      status:         'new',
      source:         'email',
      gmail_thread_id: message.threadId,
      notes:          `From: ${fromName} <${fromEmail}>\nSubject: ${subject}`,
    })
    .select()
    .single()

  if (error) throw error

  // Log the Gmail sync
  await supabaseAdmin.from('gmail_sync_log').insert({
    gmail_message_id: messageId,
    gmail_thread_id:  message.threadId,
    subject,
    from_email:       fromEmail,
    deal_id:          deal.id,
    processed:        true
  })

  // Save any PDF attachments
  await saveAttachments(gmail, message, deal.id)

  // Auto-kick off scrubbing if attachments were found
  await queueScrubJob(deal.id)

  console.log(`Created deal ${dealNumber} from ${fromEmail}`)
  return deal
}

// ─── BODY EXTRACTOR ──────────────────────────────────────────

function extractBody(payload) {
  if (payload.body?.data) {
    return Buffer.from(payload.body.data, 'base64').toString('utf-8')
  }
  if (payload.parts) {
    for (const part of payload.parts) {
      if (part.mimeType === 'text/plain' && part.body?.data) {
        return Buffer.from(part.body.data, 'base64').toString('utf-8')
      }
    }
    for (const part of payload.parts) {
      const nested = extractBody(part)
      if (nested) return nested
    }
  }
  return ''
}

// ─── EMAIL PARSER ────────────────────────────────────────────
// Tries to pull deal info from the email text
// Adjust these patterns to match how your brokers format emails

function parseDealFromEmail(subject, body, fromEmail, fromName) {
  const text = `${subject}\n${body}`.toLowerCase()

  // Amount: looks for $50,000 or 50000 or "50k"
  const amountMatch = text.match(/\$?([\d,]+)k?\b/)
  const amountStr = amountMatch?.[1]?.replace(/,/g, '') || ''
  const amount = amountStr
    ? (text.includes('k') && amountStr.length <= 3
        ? parseInt(amountStr) * 1000
        : parseInt(amountStr))
    : null

  // Business name: first line that looks like a company
  const lines = body.split('\n').map(l => l.trim()).filter(Boolean)
  const bizLine = lines.find(l => 
    l.length > 3 && l.length < 80 && 
    !l.includes('@') && !l.toLowerCase().startsWith('hi') &&
    !l.toLowerCase().startsWith('please') && !l.toLowerCase().startsWith('attached')
  ) || 'Unknown Business'

  // Phone number
  const phoneMatch = body.match(/(\(?\d{3}\)?[\s.-]\d{3}[\s.-]\d{4})/)

  return {
    businessName:    bizLine,
    contactName:     fromName,
    contactEmail:    fromEmail,
    contactPhone:    phoneMatch?.[1] || null,
    amountRequested: amount,
  }
}

// ─── ATTACHMENT SAVER ────────────────────────────────────────

async function saveAttachments(gmail, message, dealId) {
  const attachments = []
  collectAttachments(message.payload, attachments)

  for (const att of attachments) {
    try {
      let data = att.body.data
      
      // If it's a reference, fetch the actual attachment
      if (!data && att.body.attachmentId) {
        const { data: fetched } = await gmail.users.messages.attachments.get({
          userId: 'me',
          messageId: message.id,
          id: att.body.attachmentId
        })
        data = fetched.data
      }

      if (!data) continue

      const buffer = Buffer.from(data, 'base64')
      const filename = att.filename || `attachment-${Date.now()}`
      const path = `deals/${dealId}/${filename}`

      // Upload to Supabase Storage
      const { error: uploadErr } = await supabaseAdmin.storage
        .from('deal-documents')
        .upload(path, buffer, {
          contentType: att.mimeType,
          upsert: true
        })

      if (uploadErr) {
        console.error('Upload error:', uploadErr)
        continue
      }

      // Record in DB
      await supabaseAdmin.from('documents').insert({
        deal_id:      dealId,
        name:         filename,
        doc_type:     guessDocType(filename, att.mimeType),
        storage_path: path,
        mime_type:    att.mimeType,
        size_bytes:   buffer.length,
        source:       'email'
      })

    } catch (err) {
      console.error(`Failed to save attachment ${att.filename}:`, err)
    }
  }
}

function collectAttachments(payload, out) {
  if (payload.filename && payload.body) {
    out.push(payload)
  }
  if (payload.parts) {
    payload.parts.forEach(p => collectAttachments(p, out))
  }
}

function guessDocType(filename, mimeType) {
  const f = filename.toLowerCase()
  if (f.includes('statement') || f.includes('bank')) return 'bank_statement'
  if (f.includes('void') || f.includes('check')) return 'voided_check'
  if (f.includes('id') || f.includes('license') || f.includes('passport')) return 'photo_id'
  if (f.includes('contract') || f.includes('agreement')) return 'contract'
  return 'other'
}
